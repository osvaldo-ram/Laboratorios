<%- include('../includes/head.ejs') %>
<%- include('../includes/navbar.ejs') %>

<section class="card form-card">
  <p class="eyebrow">Agregar contacto</p>
  <h1>Registrar un nuevo contacto</h1>

  <form class="contact-form" action="/contactos/agregar" method="POST">
    <label for="nombre">Nombre</label>
    <input id="nombre" name="nombre" type="text" required>

    <label for="telefono">Telefono</label>
    <input id="telefono" name="telefono" type="tel" required>

    <label for="correo">Correo electronico</label>
    <input id="correo" name="correo" type="email" required>

    <label for="ciudad">Ciudad</label>
    <input id="ciudad" name="ciudad" type="text" required>

    <label for="notas">Notas</label>
    <textarea id="notas" name="notas" rows="4" placeholder="Relacion, empresa o informacion extra"></textarea>

    <button class="button" type="submit">Guardar contacto</button>
  </form>
</section>

<%- include('../includes/footer.ejs') %>
