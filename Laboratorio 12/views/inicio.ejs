<%- include('includes/head.ejs') %>
<%- include('includes/navbar.ejs') %>

<section class="hero">
  <div>
    <p class="eyebrow">Laboratorio 13</p>
    <h1>Agenda de contactos con arquitectura MVC en Node y Express.</h1>
    <p>
      Esta aplicacion separa modelo, vista y controlador para organizar mejor la logica,
      mantener rutas ligeras y hacer mas facil el crecimiento del proyecto.
    </p>
    <div class="actions">
      <a class="button" href="/contactos">Ver contactos</a>
      <a class="button button-secondary" href="/contactos/agregar">Agregar uno nuevo</a>
    </div>
  </div>
</section>

<section class="grid">
  <article class="card">
    <h2>Controladores dedicados</h2>
    <p>Las rutas ahora solo delegan el trabajo y los controladores coordinan vistas y modelo.</p>
  </article>
  <article class="card">
    <h2>Modelo reutilizable</h2>
    <p>La clase Contacto encapsula el guardado, consulta, estadisticas y favoritos.</p>
  </article>
  <article class="card">
    <h2>Nueva funcionalidad</h2>
    <p>Puedes registrar contactos como favoritos y filtrar la lista para ver solo esos elementos.</p>
  </article>
</section>

<section class="grid stats-grid">
  <article class="card stat-card">
    <p class="eyebrow">Total</p>
    <h2><%= totalContactos %></h2>
    <p>contactos registrados en el modelo.</p>
  </article>
  <article class="card stat-card">
    <p class="eyebrow">Favoritos</p>
    <h2><%= totalFavoritos %></h2>
    <p>contactos marcados para acceso rapido.</p>
  </article>
</section>

<%- include('includes/footer.ejs') %>
