<%- include('includes/head.ejs') %>
<%- include('includes/navbar.ejs') %>

<section class="hero">
  <div>
    <p class="eyebrow">Laboratorio 14</p>
    <h1>Agenda de contactos con cookies y sesiones en Node y Express.</h1>
    <p>
      Esta version conserva la arquitectura MVC del laboratorio anterior y ahora agrega
      persistencia de preferencias con cookies y estado temporal con sesiones.
    </p>
    <div class="actions">
      <a class="button" href="/contactos?favoritos=0">Ver contactos</a>
      <a class="button button-secondary" href="/contactos/agregar">Agregar uno nuevo</a>
    </div>
  </div>
</section>

<section class="grid">
  <article class="card">
    <h2>Cookie de preferencia</h2>
    <p>La lista recuerda si prefieres ver todos los contactos o solo favoritos.</p>
  </article>
  <article class="card">
    <h2>Sesion activa</h2>
    <p>La aplicacion lleva el conteo de visitas a inicio y mantiene contactos consultados recientemente.</p>
  </article>
  <article class="card">
    <h2>Flash messages</h2>
    <p>Los mensajes de exito y error duran una sola peticion y luego desaparecen.</p>
  </article>
</section>

<section class="grid stats-grid">
  <article class="card stat-card">
    <p class="eyebrow">Total</p>
    <h2><%= totalContactos %></h2>
    <p>contactos registrados en el modelo.</p>
  </article>
  <article class="card stat-card">
    <p class="eyebrow">Favoritos</p>
    <h2><%= totalFavoritos %></h2>
    <p>contactos marcados para acceso rapido.</p>
  </article>
  <article class="card stat-card">
    <p class="eyebrow">Visitas en sesion</p>
    <h2><%= visitCount %></h2>
    <p>veces que abriste esta pagina durante la sesion actual.</p>
  </article>
</section>

<section class="grid stats-grid">
  <article class="card">
    <p class="eyebrow">Cookie de lista</p>
    <h2><%= preferredView %></h2>
    <p>La preferencia guardada en cookie para la vista de contactos es <strong><%= preferredView.toLowerCase() %></strong>.</p>
  </article>
  <article class="card">
    <p class="eyebrow">Ultima cookie</p>
    <h2>Ultimo contacto visto</h2>
    <p><%= lastViewedContact %></p>
  </article>
</section>

<section class="card page-card">
  <p class="eyebrow">Sesion</p>
  <h2>Contactos vistos recientemente</h2>
  <% if (recentContacts.length > 0) { %>
    <ul class="recent-list">
      <% for (let contacto of recentContacts) { %>
        <li>
          <a class="text-link" href="/contactos/<%= contacto.id %>"><%= contacto.nombre %></a>
          <span><%= contacto.ciudad %></span>
        </li>
      <% } %>
    </ul>
  <% } else { %>
    <p>Todavia no has abierto detalles de contactos en esta sesion.</p>
  <% } %>
</section>

<%- include('includes/footer.ejs') %>
