<%- include('../includes/head.ejs') %>
<%- include('../includes/navbar.ejs') %>

<section class="section-header">
  <div>
    <p class="eyebrow">Lista de contactos</p>
    <h1><%= onlyFavorites ? 'Contactos favoritos' : 'Contactos guardados' %></h1>
  </div>
  <div class="actions compact-actions">
    <a class="button button-secondary" href="<%= onlyFavorites ? '/contactos?favoritos=0' : '/contactos?favoritos=1' %>">
      <%= onlyFavorites ? 'Ver todos' : 'Ver favoritos' %>
    </a>
    <a class="button" href="/contactos/agregar">Nuevo contacto</a>
  </div>
</section>

<section class="card status-card">
  <p><strong>Preferencia guardada en cookie:</strong> <%= preferredViewLabel %>.</p>
</section>

<% if (contactos.length > 0) { %>
  <section class="grid">
    <% for (let contacto of contactos) { %>
      <article class="card <%= contacto.favorito ? 'favorite-card' : '' %>">
        <div class="card-heading">
          <h2><%= contacto.nombre %></h2>
          <% if (contacto.favorito) { %>
            <span class="badge">Favorito</span>
          <% } %>
        </div>
        <p><strong>Telefono:</strong> <%= contacto.telefono %></p>
        <p><strong>Correo:</strong> <%= contacto.correo %></p>
        <p><strong>Ciudad:</strong> <%= contacto.ciudad %></p>
        <div class="actions compact-actions">
          <form action="/contactos/<%= contacto.id %>/favorito" method="POST">
            <button class="button button-secondary" type="submit">
              <%= contacto.favorito ? 'Quitar favorito' : 'Marcar favorito' %>
            </button>
          </form>
          <a class="text-link" href="/contactos/<%= contacto.id %>">Ver detalle</a>
        </div>
      </article>
    <% } %>
  </section>
<% } else { %>
  <section class="card page-card empty-state">
    <h2><%= onlyFavorites ? 'No hay contactos favoritos todavia' : 'Aun no hay contactos registrados' %></h2>
    <p>
      <%= onlyFavorites ? 'Marca algun contacto como favorito para verlo aqui.' : 'Agrega el primer contacto desde el formulario para verlo aqui.' %>
    </p>
    <a class="button" href="/contactos/agregar">Ir al formulario</a>
  </section>
<% } %>

<%- include('../includes/footer.ejs') %>
